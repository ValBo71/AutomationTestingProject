                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"id\": 999111,\n  \"username\": \"{{username}}\",\n  \"firstName\": \"E2E\",\n  \"lastName\": \"User\",\n  \"email\": \"{{e2eEmail}}\",\n  \"password\": \"SecretPassword123\",\n  \"phone\": \"{{e2ePhone}}\",\n  \"userStatus\": 0\n}"
