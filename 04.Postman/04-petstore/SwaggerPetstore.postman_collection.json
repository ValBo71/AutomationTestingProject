        {
            "name": "4. E2E Integration Scenario",
            "description": "Chained E2E flow: Create User -> Login -> Create Pet -> Verify Pet -> Place Order -> Verify Order -> Delete Order -> Delete Pet -> Delete User.",
            "item": [
                {
                    "name": "E2E 1: POST Create User",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "// Generate dynamic username and store in collectionVariables",
                                    "const timestamp = Date.now();",
                                    "const username = \"e2e_user_\" + timestamp;",
                                    "pm.collectionVariables.set(\"username\", username);",
                                    "",
                                    "const e2eEmail = \"e2e_email_\" + timestamp + \"@example.com\";",
                                    "pm.collectionVariables.set(\"e2eEmail\", e2eEmail);",
                                    "",
                                    "const e2ePhone = \"1\" + String(timestamp).substring(4);",
                                    "pm.collectionVariables.set(\"e2ePhone\", e2ePhone);",
                                    "console.log(\"E2E User Generated - Username: \" + username);"
                                ],
                                "type": "text/javascript"
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
